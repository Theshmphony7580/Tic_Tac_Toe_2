# Database
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://admin:changeme@postgres:5432/talentintel

# Redis
REDIS_URL=redis://redis:6379/0

# LLM (Groq - free tier)
GROQ_API_KEY=your_groq_api_key_here

# File Storage (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Security
API_SECRET_KEY=your-secret-here

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Internal Service URLs
PARSER_SERVICE_URL=http://parser:8001
NORMALIZATION_SERVICE_URL=http://normalizer:8002
MATCHING_SERVICE_URL=http://matcher:8003
